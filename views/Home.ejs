<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #d4edda; /* light green */
      margin: 0;
      padding: 0;
    }

    .navbar {
      background-color: #81c784; /* soft green */
    }

    .profile-circle {
      width: 40px;
      height: 40px;
      background-color: #2e7d32;
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 18px;
      cursor: pointer;
    }

    .dropdown-menu {
      right: 0;
      left: auto;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-light px-4">
    <a class="navbar-brand text-white fw-bold" href="#">MyApp</a>
    <div class="collapse navbar-collapse justify-content-end">
      <ul class="navbar-nav">

        <!-- Profile Icon Dropdown -->
        <li class="nav-item dropdown ms-3">
          <a 
            class="nav-link dropdown-toggle d-flex align-items-center"
            href="#"
            id="profileDropdown"
            role="button"
            data-bs-toggle="dropdown"
            aria-expanded="false">
            <div class="profile-circle" title="<%= userEmail %>">
              <%= userEmail.charAt(0).toUpperCase() %>
            </div>
          </a>
          <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
            <li><a class="dropdown-item text-danger" href="/deleteaccount">Delete Account</a></li>
            <li><a class="dropdown-item text-danger" href="/">Signout</a></li>

            
          </ul>
        </li>

      </ul>
    </div>
  </nav>

  <!-- Content -->
  <div class="container mt-5">
    <h3>Welcome, <%= userEmail %>!</h3>
    <p></p>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
