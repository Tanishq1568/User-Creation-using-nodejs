<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Delete Account</title>
    <!-- Bootstrap CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #d4edda;
        }
        .delete-container {
            max-width: 450px;
            margin: 80px auto;
            padding: 30px;
            background-color: white;
            box-shadow: 0 0 10px rgba(0,0,0,0.15);
            border-radius: 8px;
        }
        .warning-text {
            color: #dc3545;
            font-weight: 500;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <div class="delete-container">
        <h3 class="text-center mb-4" style="padding-bottom: 30px;">Delete Account</h3>
        <p class="text-center warning-text">⚠️ This action is irreversible. Please confirm your details.</p>

        <form action="/deleteaccount" method="POST">
            <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <input 
                    type="email" 
                    class="form-control" 
                    id="email" 
                    name="email" 
                    required>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Confirm Password</label>
                <input 
                    type="password" 
                    class="form-control" 
                    id="password" 
                    name="password" 
                    required>
            </div>
            <button type="submit" class="btn btn-danger w-100" style="background-color: #4CAF50; border-color: #4CAF50; color: white;">Delete Account</button>

            <div class="text-center mt-3">
                <span>Changed your mind? </span>
                <a href="/" class="text-decoration-none">Login</a>
            </div>
        </form>
    </div>

    <script>
    const params = new URLSearchParams(window.location.search);
    if (params.get("success") === "true") {
        alert("Account deleted successfully!");
        window.location.href = "/signup";
    }
</script>

</body>
</html>
